{
  "name": "kafka-cost-control-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test:watch": "ng test",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "generate": "rm -f ./src/generated/graphql/* && ./node_modules/.bin/graphql-codegen --config graphql/codegen.yml",
    "update-schema": "wget -O graphql/schema.graphql http://localhost:8080/graphql/schema.graphql",
    "lint": "ng lint",
    "format": "prettier --write .",
    "prettier": "npm run format"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@apollo/client": "^4.0.10",
    "@ngrx/signals": "^21.0.1",
    "apollo-angular": "^14.1.0",
    "echarts": "^6.0.0",
    "file-saver-es": "^2.0.5",
    "graphql": "^16.12.0",
    "jspdf": "^4.2.1",
    "ngx-echarts": "^22.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "@ngrx/signals": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    }
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/typescript": "^5.0.6",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.1",
    "@graphql-codegen/typescript-apollo-client-helpers": "^3.0.1",
    "@graphql-codegen/typescript-operations": "^5.0.5",
    "@types/file-saver-es": "^2.0.3",
    "@types/jasmine": "~5.1.13",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "angular-eslint": "22.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
